{% extends 'base.html.twig' %}

{% block body %}
    <style>
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        /* Estilos Claros y Modernos */
        body { background-color: #fcfcfc; color: #444; }
        .card-deidad { background: #ffffff; padding: 30px; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); border: 1px solid #f0f0f0; }
        tr.fila-usuario:hover { background-color: #f9fbff; cursor: pointer; transition: 0.2s; }

        /* Botones con Colores Suaves */
        .btn-pag { padding: 8px 14px; border: 1px solid #e0e0e0; border-radius: 8px; cursor: pointer; font-weight: 600; background: #fff; color: #666; transition: 0.2s; }
        .btn-pag:hover:not(:disabled) { background: #f8f9fa; color: #007bff; border-color: #007bff; }
        .btn-pag:disabled { cursor: not-allowed; opacity: 0.4; }
        .active { background: #e7f1ff !important; color: #007bff !important; border-color: #b6d4fe !important; }

        .input-busqueda { padding: 10px 15px; border: 1px solid #e0e0e0; border-radius: 10px; outline: none; width: 250px; transition: 0.3s; background: #fff; }
        .input-busqueda:focus { border-color: #007bff; box-shadow: 0 0 0 4px rgba(0,123,255,0.05); }

        /* Alertas de Excepción (Rojo Suave) */
        .alerta-deidad {
            display: none; padding: 15px; border-radius: 10px; margin-bottom: 20px;
            font-weight: 600; animation: fadeIn 0.3s; border: 1px solid #feb2b2; background: #fff5f5; color: #c53030;
        }

        /* Botón de Editar (Gris Claro en lugar de Negro) */
        #btn-edit-link { background: #f0f2f5; color: #495057; border: 1px solid #dee2e6; }
        #btn-edit-link:hover { background: #e2e6ea; }
    </style>

    <div style="max-width: 900px; margin: 40px auto; font-family: 'Inter', sans-serif;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 id="titulo-pagina" style="color: #1a1a1a; font-weight: 800; letter-spacing: -0.5px;">Gestión de Usuarios</h2>
            <div style="display: flex; gap: 12px;">
                <input type="text" id="input-buscar" placeholder="🔍 Buscar nombre..." class="input-busqueda">
                <button id="btn-abrir-form" style="background: #007bff; color: white; border: none; padding: 10px 22px; border-radius: 10px; cursor: pointer; font-weight: 600; transition: 0.2s;">+ Nueva Persona</button>
            </div>
        </div>

        {# VISTA 1: TABLA #}
        <div id="vista-tabla" style="animation: fadeIn 0.4s;">
            <div class="card-deidad">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                    <tr style="border-bottom: 2px solid #f8f9fa; text-align: left; color: #a0aec0; font-size: 12px; text-transform: uppercase; letter-spacing: 1px;">
                        <th style="padding: 18px;">Nombre Completo</th>
                        <th style="padding: 18px;">Correo Electrónico</th>
                    </tr>
                    </thead>
                    <tbody id="cuerpo-tabla" style="color: #4a5568; font-size: 15px;"></tbody>
                </table>
                <div id="paginacion" style="display: flex; gap: 8px; justify-content: center; margin-top: 30px;"></div>
            </div>
        </div>

        {# VISTA 2: FORMULARIO #}
        <div id="vista-formulario" style="display: none; animation: fadeIn 0.4s;">
            <div class="card-deidad">
                <h3 id="form-titulo" style="margin-bottom: 25px; border-left: 4px solid #007bff; padding-left: 15px; color: #2d3748;">Registrar Persona</h3>
                <div id="alerta-msj" class="alerta-deidad"></div>

                <form id="form-registro" novalidate>
                    <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                        <div style="flex: 1;">
                            <label style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #718096;">Nombre:</label>
                            <input type="text" id="nombre" name="nombre" placeholder="Ej. Juan Pérez" style="width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px; outline: none; transition: 0.3s;">
                        </div>
                        <div style="flex: 1;">
                            <label style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #718096;">Email:</label>
                            <input type="email" id="email" name="email" placeholder="correo@ejemplo.com" style="width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px; outline: none; transition: 0.3s;">
                        </div>
                    </div>
                    <div style="display: flex; gap: 12px; margin-top: 35px;">
                        <button type="submit" id="btn-guardar" style="background: #38a169; color: white; border: none; padding: 12px 35px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s;">Guardar Datos</button>
                        <button type="button" onclick="regresarALista()" style="background: #edf2f7; color: #4a5568; border: none; padding: 12px 35px; border-radius: 10px; cursor: pointer; font-weight: 600;">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>

        {# VISTA 3: DETALLE #}
        <div id="vista-detalle" style="display: none; animation: fadeIn 0.4s;">
            <div class="card-deidad" style="text-align: center; padding: 50px;">
                <div style="width: 80px; height: 80px; background: #ebf4ff; border-radius: 50%; margin: 0 auto 25px; display: flex; align-items: center; justify-content: center; font-size: 32px; color: #3182ce;">👤</div>
                <h3 id="det-nombre" style="font-size: 28px; margin: 0; color: #1a202c; font-weight: 800;"></h3>
                <p id="det-email" style="color: #3182ce; margin: 12px 0; font-size: 18px; font-weight: 500;"></p>
                <div style="display: flex; justify-content: center; gap: 15px; margin-top: 35px; border-top: 1px solid #f0f0f0; padding-top: 30px;">
                    <button id="btn-edit-link" style="padding: 12px 30px; border-radius: 10px; cursor: pointer; font-weight: 700;">Editar</button>
                    <button id="btn-delete-link" style="background: #fff5f5; color: #e53e3e; border: 1px solid #feb2b2; padding: 12px 30px; border-radius: 10px; cursor: pointer; font-weight: 700;">Eliminar</button>
                    <button onclick="regresarALista()" style="background: #f7fafc; border: 1px solid #edf2f7; padding: 12px 30px; border-radius: 10px; cursor: pointer; color: #718096;">Volver</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('form-registro');
        const alertBox = document.getElementById('alerta-msj');
        const inputBuscar = document.getElementById('input-buscar');
        let editandoId = null;
        let busquedaActual = '';

        function lanzarAlerta(msj) {
            alertBox.innerText = "🚨 " + msj;
            alertBox.style.display = 'block';
            window.scrollTo({ top: 0, behavior: 'smooth' });
            setTimeout(() => { alertBox.style.display = 'none'; }, 5000);
        }

        inputBuscar.addEventListener('input', (e) => {
            busquedaActual = e.target.value;
            cargarPersonas(1);
        });

        function regresarALista() {
            document.getElementById('vista-tabla').style.display = 'block';
            document.getElementById('vista-formulario').style.display = 'none';
            document.getElementById('vista-detalle').style.display = 'none';
            document.getElementById('btn-abrir-form').style.display = 'block';
            inputBuscar.style.display = 'block';
            alertBox.style.display = 'none';
            editandoId = null;
            form.reset();
            cargarPersonas();
        }

        document.getElementById('btn-abrir-form').onclick = () => {
            document.getElementById('vista-tabla').style.display = 'none';
            document.getElementById('vista-formulario').style.display = 'block';
            document.getElementById('btn-abrir-form').style.display = 'none';
            inputBuscar.style.display = 'none';
            document.getElementById('form-titulo').innerText = "Nuevo Registro";
        };

        async function cargarPersonas(pagina = 1) {
            const res = await fetch(`/api/personas?page=${pagina}`);
            const data = await res.json();
            let itemsFiltrados = data.items;
            if (busquedaActual) {
                itemsFiltrados = itemsFiltrados.filter(p => p.nombre.toLowerCase().includes(busquedaActual.toLowerCase()));
            }
            const cuerpo = document.getElementById('cuerpo-tabla');
            cuerpo.innerHTML = '';
            itemsFiltrados.forEach(p => {
                const fila = document.createElement('tr');
                fila.className = 'fila-usuario';
                fila.innerHTML = `<td style="padding: 18px; font-weight: 600;">${p.nombre}</td><td style="padding: 18px; color: #718096;">${p.email}</td>`;
                fila.onclick = () => verDetalle(p.id);
                cuerpo.appendChild(fila);
            });
            actualizarPaginador(data.pages, data.current_page);
        }

        async function verDetalle(id) {
            const res = await fetch(`/api/personas/${id}`);
            const p = await res.json();
            document.getElementById('det-nombre').innerText = p.nombre;
            document.getElementById('det-email').innerText = p.email;
            document.getElementById('btn-delete-link').onclick = () => eliminar(id);
            document.getElementById('btn-edit-link').onclick = () => {
                editandoId = p.id;
                document.getElementById('nombre').value = p.nombre;
                document.getElementById('email').value = p.email;
                document.getElementById('vista-detalle').style.display = 'none';
                document.getElementById('vista-formulario').style.display = 'block';
            };
            document.getElementById('vista-tabla').style.display = 'none';
            document.getElementById('vista-detalle').style.display = 'block';
            document.getElementById('btn-abrir-form').style.display = 'none';
            inputBuscar.style.display = 'none';
        }

        form.onsubmit = async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(form).entries());

            // --- VALIDACIONES PERRONAS ---
            if (!data.nombre.trim()) return lanzarAlerta("El nombre es obligatorio, no lo dejes vacío.");
            if (!data.email.trim()) return lanzarAlerta("El correo es indispensable para el registro.");

            // Regex de Correo Válido
            const regexEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!regexEmail.test(data.email)) return lanzarAlerta("Ese correo no parece válido. Revisa el @ y el dominio.");

            // Regex de Nombre (solo letras y espacios)
            const regexNombre = /^[a-zA-ZÁÉÍÓÚáéíóúñÑ\s]+$/;
            if (!regexNombre.test(data.nombre)) return lanzarAlerta("El nombre solo puede contener letras y espacios.");

            const url = editandoId ? `/api/personas/${editandoId}` : '/api/personas/nuevo';

            try {
                const response = await fetch(url, {
                    method: editandoId ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.error || "Algo tronó en el servidor.");
                }

                alert(editandoId ? "¡Deidad actualizada!" : "¡Deidad guardada con éxito!");
                regresarALista();
            } catch (err) {
                lanzarAlerta("Excepción: " + err.message);
            }
        };

        async function eliminar(id) {
            if (confirm("¿Estás seguro de borrar a esta deidad?")) {
                await fetch(`/api/personas/${id}`, { method: 'DELETE' });
                regresarALista();
            }
        }

        function actualizarPaginador(total, actual) {
            const cont = document.getElementById('paginacion');
            cont.innerHTML = '';
            for (let i = 1; i <= total; i++) {
                const btn = document.createElement('button');
                btn.innerText = i;
                btn.className = `btn-pag ${i === actual ? 'active' : ''}`;
                btn.onclick = () => cargarPersonas(i);
                cont.appendChild(btn);
            }
        }

        cargarPersonas();
    </script>
{% endblock %}
